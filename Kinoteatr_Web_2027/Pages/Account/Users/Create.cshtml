@page
@model Kinoteatr_Web_2027.Pages.Account.Users.CreateModel
@{
}

<div class="container mt-4">

    <h2>Добавить пользователя</h2>

    <form method="post">

        <div class="mb-3">
            <label asp-for="User.Email" class="form-label">Почта</label>
            <input asp-for="User.Email" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="User.Password" class="form-label">Пароль</label>
            <input asp-for="User.Password"
                   type="password"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="User.Role" class="form-label">Роль</label>
            <input asp-for="User.Role" class="form-control" />
        </div>

        <button type="submit" class="btn btn-success">
            Создать
        </button>

        <a asp-page="Index" class="btn btn-secondary">
            Назад
        </a>

    </form>

</div>