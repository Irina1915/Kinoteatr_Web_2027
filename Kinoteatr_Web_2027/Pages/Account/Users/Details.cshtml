@page
@model Kinoteatr_Web_2027.Pages.Account.Users.DetailsModel
@{
}

<div class="container mt-4">

    <h2>Информация о пользователи</h2>

    <div class="card">

        <div class="card-body">

            @if (Model.User.Avatar != null)
            {
                <div class="mb-3">
                    <img style="max-width:150px;"
                         src="data:image/png;base64,@Convert.ToBase64String(Model.User.Avatar)" />
                </div>
            }
            <p>Почта<b>Email:</b> @Model.User.Email</p>
            <p>Роль<b>Role:</b> @Model.User.Role</p>

        </div>

    </div>

    <br>

    <a asp-page="Edit" asp-route-id="@Model.User.Id"
       class="btn btn-warning">
        Редактировать
    </a>

    <a asp-page="Index" class="btn btn-secondary">
        Назад
    </a>

</div>