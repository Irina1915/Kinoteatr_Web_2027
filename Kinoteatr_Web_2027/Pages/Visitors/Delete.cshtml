@page
@model Kinoteatr_Web_2027.Pages.Visitors.DeleteModel

@{
    ViewData["Title"] = "Удалить";
}

<h1>Удалить Зрителя</h1>

<h3>Вы уверены?</h3>

<div>
    <p><strong>@Model.Visitor.LastName</strong></p>
    <p>Email: @Model.Visitor.Email</p>
    <p>Телефон: @Model.Visitor.Phone</p>
    <p>Дата рождения: @Model.Visitor.BirthDate</p>
</div>

<form method="post">
    <input type="hidden" asp-for="Visitor.LastName" />
    <button type="submit">Удалить</button>
</form>

<a asp-page="Index">Отмена</a>