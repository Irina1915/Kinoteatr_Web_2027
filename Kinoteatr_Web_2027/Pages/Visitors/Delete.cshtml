@page
@model Kinoteatr_Web_2027.Pages.Visitors.DeleteModel

@{
    ViewData["Title"] = "Удалить";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

        <div class="card border-danger shadow-sm mt-4">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Подтверждение удаления</h5>
            </div>

            <div class="card-body">
                <p class="mb-3">
                    Вы действительно хотите удалить зрителя:
                </p>

                <div class="alert alert-light border">
                    <strong>@Model.Visitor.LastName</strong><br />
                    <small class="text-muted">@Model.Visitor.Email</small>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Visitor.Id" />

                    <div class="d-flex justify-content-between">
                        <a asp-page="Index" class="btn btn-outline-secondary">
                            Отмена
                        </a>

                        <button type="submit" class="btn btn-danger">
                            Удалить
                        </button>
                    </div>
                </form>
            </div>

        </div>

    </div>
</div>