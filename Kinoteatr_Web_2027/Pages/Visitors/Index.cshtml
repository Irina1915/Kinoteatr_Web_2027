@page
@model Kinoteatr_Web_2027.Pages.Visitors.IndexModel

@{
    ViewData["Title"] = "Список";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-10">

        <div class="card shadow-sm mt-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Список студентов</h5>

                <a asp-page="Create" class="btn btn-light btn-sm">
                    + Добавить студента
                </a>
            </div>

            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Фамилия</th>
                                <th>Email</th>
                                <th>Телефон</th>
                                <th>Дата рождения</th>
                                <th class="text-end">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var visitor in Model.Visitors)
                            {
                                <tr>
                                    <td class="fw-semibold">
                                        @visitor.LastName
                                    </td>

                                    <td>
                                        <span class="text-muted">
                                            @visitor.Email
                                        </span>
                                    </td>

                                    <td>
                                        @(string.IsNullOrEmpty(visitor.Phone)
                                                                            ? "—"
                                                                            : visitor.Phone)
                                </td>

                                    <td>
                                        @visitor.BirthDate.ToShortDateString()
                                    </td>

                                    <td class="text-end">
                                        <a asp-page="Details"
                                           asp-route-id="@visitor.Id"
                                           class="btn btn-sm btn-outline-primary me-1">
                                            Открыть
                                        </a>

                                        <a asp-page="Edit"
                                           asp-route-id="@visitor.Id"
                                           class="btn btn-sm btn-outline-warning me-1">
                                            Изменить
                                        </a>

                                        <a asp-page="Delete"
                                           asp-route-id="@visitor.Id"
                                           class="btn btn-sm btn-outline-danger">
                                            Удалить
                                        </a>
                                    </td>
                                </tr>
                                                        }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>
</div>