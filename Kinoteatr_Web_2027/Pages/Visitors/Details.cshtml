@page
@model Kinoteatr_Web_2027.Pages.Visitors.DetailsModel

@{
    ViewData["Title"] = "Информация";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

        <div class="card shadow-sm mt-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Информация о студенте</h5>
            </div>

            <div class="card-body">

                <dl class="row mb-0">
                    <dt class="col-sm-4">Фамилия</dt>
                    <dd class="col-sm-8">@Model.Visitor.LastName</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Visitor.Email</dd>

                    <dt class="col-sm-4">Телефон</dt>
                    <dd class="col-sm-8">
                        @(string.IsNullOrEmpty(Model.Visitor.Phone)
                                                ? "—"
                                                : Model.Visitor.Phone)
                    </dd>

                    <dt class="col-sm-4">Дата рождения</dt>
                    <dd class="col-sm-8">
                        @Model.Visitor.BirthDate.ToShortDateString()
                    </dd>
                </dl>

            </div>

            <div class="card-footer d-flex justify-content-between">
                <a asp-page="Index" class="btn btn-outline-secondary">
                    Назад
                </a>

                <div>
                    <a asp-page="Edit"
                       asp-route-id="@Model.Visitor.Id"
                       class="btn btn-warning me-2">
                        Редактировать
                    </a>

                    <a asp-page="Delete"
                       asp-route-id="@Model.Visitor.Id"
                       class="btn btn-danger">
                        Удалить
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>