@page
@model Kinoteatr_Web_2027.Pages.Visitors.DetailsModel

@{
    ViewData["Title"] = "Информация";
}

<h1>Информация об участнике</h1>

<div>
    <p><strong>ФИО:</strong> @Model.Visitor.LastName</p>
    <p><strong>Телефон:</strong> @Model.Visitor.Email</p>
    <p><strong>Email:</strong> @Model.Visitor.Phone</p>
    <p><strong>Дата рождения:</strong> @Model.Visitor.BirthDate</p>
</div>

<p>
    <a asp-page="Index">Назад к списку</a>
</p>
