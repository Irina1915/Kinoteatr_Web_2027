@page
@model Kinoteatr_Web_2027.Pages.Visitors.EditModel

@{
    ViewData["Title"] = "Редактирование зрителей";
}

<h1>Редактировать зрителей</h1>

<form method="post">
    <input type="hidden" asp-for="Visitor.LastName" />
    <div>
        <label>Email</label><br />
        <input asp-for="Visitor.Email" />
    </div>
    <div>
        <label>Телефон</label><br />
        <input asp-for="Visitor.Phone" type="email" />
    </div>
    <div>
        <label>Дата рождения</label><br />
        <input asp-for="Visitor.BirthDate" type="date" />
    </div>

    <button type="submit">Сохранить</button>
</form>

<a asp-page="Index">Назад</a>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
